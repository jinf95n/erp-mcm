// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  rol       String   @default("socio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Persona {
  id               String   @id @default(cuid())
  nombre           String
  rol              String   @default("otro")   // ceo | cto | dev | pm | vendedor | otro
  esSocio          Boolean  @default(false)    // recibe split de ganancia agencia
  tipoCompensacion String   @default("ars")    // porcentaje | ars | usd
  monto            Float    @default(0)
  email            String?
  telefono         String?
  notas            String?
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  costos         CostoVenta[]
  distribuciones Distribucion[]
}

model Cliente {
  id        String    @id @default(cuid())
  nombre    String
  empresa   String?
  email     String?
  telefono  String?
  sitioWeb  String?
  vendedor  String
  notas     String?
  activo    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ventas         Venta[]
  mantenimientos Mantenimiento[]
}

model Venta {
  id             String    @id @default(cuid())
  nombreProyecto String
  tipoServicio   String
  precioTotal    Float
  pagoInicial    Float
  cantidadCuotas Int       @default(0)
  valorCuota     Float     @default(0)
  estado         String    @default("activo")
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clienteId      String
  cliente        Cliente        @relation(fields: [clienteId], references: [id])
  pagos          Pago[]
  costos         CostoVenta[]
  distribuciones Distribucion[]
}

model CostoVenta {
  id            String   @id @default(cuid())
  descripcion   String
  monto         Float
  personaNombre String?
  personaId     String?
  persona       Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  ventaId       String
  venta         Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Pago {
  id       String   @id @default(cuid())
  monto    Float
  fecha    DateTime @default(now())
  tipoPago String
  notas    String?
  ventaId  String
  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distribuciones Distribucion[]
}

model Distribucion {
  id            String    @id @default(cuid())
  descripcion   String
  monto         Float
  estado        String    @default("pendiente") // pendiente | pagado
  tipo          String    @default("costo")     // costo | ganancia
  fechaPago     DateTime?
  notas         String?

  ventaId       String?
  venta         Venta?   @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  pagoId        String?
  pago          Pago?    @relation(fields: [pagoId], references: [id], onDelete: SetNull)

  personaId     String?
  persona       Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  personaNombre String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gasto {
  id          String   @id @default(cuid())
  descripcion String
  monto       Float
  categoria   String   @default("herramienta")
  fecha       DateTime @default(now())
  recurrente  Boolean  @default(false)
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Mantenimiento {
  id                  String   @id @default(cuid())
  descripcion         String
  montoMensual        Float
  costoDesarrollador  Float    @default(0)
  desarrolladorNombre String?
  activo              Boolean  @default(true)
  fechaInicio         DateTime @default(now())
  notas               String?
  clienteId           String?
  cliente             Cliente? @relation(fields: [clienteId], references: [id])
  cobros              CobroMantenimiento[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CobroMantenimiento {
  id              String        @id @default(cuid())
  monto           Float
  fecha           DateTime      @default(now())
  notas           String?
  mantenimientoId String
  mantenimiento   Mantenimiento @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
